{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanOrchestratorTasks",
  "description": "Output of parse-bullets.py (without `domains`/`routing`) or classify-tasks.py (with them).",
  "type": "object",
  "required": ["tasks", "count"],
  "properties": {
    "target": {
      "description": "Optional target directory parsed from a leading `target: <path>` line in $ARGUMENTS.",
      "type": ["string", "null"]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^T\\d+$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "frontend",
                "backend",
                "database",
                "infrastructure",
                "testing",
                "security",
                "documentation"
              ]
            },
            "minItems": 1
          },
          "default_tagged": {
            "description": "True when the classifier fell back to the default domain because no keyword matched.",
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "routing": {
      "description": "Domain -> ordered task IDs mapping; only present after classify-tasks.py.",
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "pattern": "^T\\d+$" }
      }
    },
    "agent_count_estimate": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
