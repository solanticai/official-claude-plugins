{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevSecOps Supply Chain Audit Findings",
  "type": "object",
  "required": ["audit_id", "audited_at", "mode", "ecosystems", "slsa_level", "findings", "aggregate_score", "verdict"],
  "properties": {
    "audit_id": { "type": "string" },
    "audited_at": { "type": "string", "format": "date-time" },
    "mode": { "type": "string", "enum": ["static", "live", "apply"] },
    "ecosystems": { "type": "array", "items": { "type": "string" } },
    "slsa_level": { "type": "integer", "minimum": 0, "maximum": 4 },
    "aggregate_score": { "type": "number" },
    "verdict": { "type": "string", "enum": ["PASS", "PASS WITH WARNINGS", "CONDITIONAL", "FAIL"] },
    "category_scores": {
      "type": "object",
      "properties": {
        "A_pinning": { "type": "number" },
        "B_vulnerabilities": { "type": "number" },
        "C_secrets": { "type": "number" },
        "D_sbom_provenance": { "type": "number" },
        "E_image_signing": { "type": "number" },
        "F_branch_protection": { "type": "number" },
        "G_codeowners": { "type": "number" },
        "H_automation": { "type": "number" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "subtype", "severity", "target", "evidence", "remediation"],
        "properties": {
          "id": { "type": "string", "pattern": "^SEC-\\d{3,}$" },
          "category": { "type": "string", "enum": ["A", "B", "C", "D", "E", "F", "G", "H"] },
          "subtype": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "INFO"] },
          "target": { "type": "string" },
          "ecosystem": { "type": "string", "nullable": true },
          "cve_ids": { "type": "array", "items": { "type": "string" } },
          "in_kev_catalogue": { "type": "boolean" },
          "evidence": { "type": "string" },
          "remediation": { "type": "string" },
          "auto_applicable": { "type": "boolean" },
          "source": { "type": "string", "enum": ["static-analysis", "live-scan", "git-history"] }
        }
      }
    },
    "vulnerability_summary": {
      "type": "object",
      "nullable": true,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "critical": { "type": "integer" },
          "high": { "type": "integer" },
          "medium": { "type": "integer" },
          "low": { "type": "integer" }
        }
      }
    }
  }
}
