# -----------------------------------------------------------------------------
# CT-003 — HIGH — C.1 (secret ARG)
# Target: Dockerfile:7
# Evidence: `ARG NPM_TOKEN=` bakes any supplied value into image history.
# -----------------------------------------------------------------------------
# Replace with BuildKit secret mount:
# syntax=docker/dockerfile:1.7
RUN --mount=type=secret,id=npm_token \
    NPM_TOKEN=$(cat /run/secrets/npm_token) npm ci

