{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CI/CD Pipeline Audit Findings",
  "type": "object",
  "required": ["audit_id", "audited_at", "mode", "platforms", "workflows_audited", "findings", "aggregate_score", "verdict"],
  "properties": {
    "audit_id": { "type": "string", "description": "UUID for this audit run" },
    "audited_at": { "type": "string", "format": "date-time" },
    "mode": { "type": "string", "enum": ["static", "live", "apply", "runtime"] },
    "platforms": { "type": "array", "items": { "type": "string" } },
    "workflows_audited": { "type": "integer" },
    "aggregate_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "verdict": { "type": "string", "enum": ["PASS", "PASS WITH WARNINGS", "CONDITIONAL", "FAIL"] },
    "category_scores": {
      "type": "object",
      "properties": {
        "A_security": { "type": "number" },
        "B_reliability": { "type": "number" },
        "C_reproducibility": { "type": "number" },
        "D_speed_cache": { "type": "number" },
        "E_supply_chain": { "type": "number" },
        "F_secrets_hygiene": { "type": "number" },
        "G_deploy_safety": { "type": "number" },
        "H_observability": { "type": "number" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "subtype", "severity", "target", "evidence", "remediation"],
        "properties": {
          "id": { "type": "string", "pattern": "^CI-\\d{3,}$" },
          "category": { "type": "string", "enum": ["A", "B", "C", "D", "E", "F", "G", "H"] },
          "subtype": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "INFO"] },
          "target": { "type": "string", "description": "file:line — e.g. '.github/workflows/release.yml:42'" },
          "evidence": { "type": "string", "description": "excerpt + plain-language explanation" },
          "remediation": { "type": "string", "description": "suggested fix as commented YAML or instruction" },
          "auto_applicable": { "type": "boolean" },
          "source": { "type": "string", "enum": ["static-analysis", "live-inspection", "runtime-observed"] },
          "platform": { "type": "string" }
        }
      }
    },
    "pattern_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern_id", "summary", "affected_files", "severity"],
        "properties": {
          "pattern_id": { "type": "string" },
          "summary": { "type": "string" },
          "affected_files": { "type": "array", "items": { "type": "string" } },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "INFO"] }
        }
      }
    },
    "runtime_baseline": {
      "type": "object",
      "nullable": true,
      "properties": {
        "workflow": { "type": "string" },
        "duration_seconds": { "type": "integer" },
        "cache_hit_rate": { "type": "number" },
        "dispatched_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
