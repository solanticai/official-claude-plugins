{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anthril.com/schemas/skill-evaluator/findings.schema.json",
  "title": "skill-evaluator findings",
  "type": "object",
  "required": ["schema_version", "evaluator_version", "evaluated_at", "target", "score", "findings"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "evaluator_version": { "type": "string" },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["full", "fast"] },
    "target": {
      "type": "object",
      "required": ["skill_name", "plugin_name", "target_dir", "skill_md_lines"],
      "properties": {
        "skill_name": { "type": "string" },
        "plugin_name": { "type": "string" },
        "target_dir": { "type": "string" },
        "skill_md_lines": { "type": "integer", "minimum": 0 }
      }
    },
    "score": {
      "type": "object",
      "required": ["total", "grade", "dimensions"],
      "properties": {
        "total": { "type": "number", "minimum": 0, "maximum": 100 },
        "grade": { "enum": ["A", "B", "C", "D", "F"] },
        "dimensions": {
          "type": "object",
          "properties": {
            "discovery_metadata":       { "$ref": "#/definitions/dimension" },
            "scope_focus":              { "$ref": "#/definitions/dimension" },
            "conciseness":              { "$ref": "#/definitions/dimension" },
            "information_architecture": { "$ref": "#/definitions/dimension" },
            "content_quality":          { "$ref": "#/definitions/dimension" },
            "tool_security":            { "$ref": "#/definitions/dimension" },
            "testing_examples":         { "$ref": "#/definitions/dimension" },
            "standards_compliance":     { "$ref": "#/definitions/dimension" }
          },
          "additionalProperties": false
        }
      }
    },
    "frontmatter": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "prioritised_fixes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^C[0-9]{2,3}$" }
    },
    "files_inspected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "lines", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "lines": { "type": "integer", "minimum": 0 },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "definitions": {
    "dimension": {
      "type": "object",
      "required": ["score", "weight", "grade"],
      "properties": {
        "score":  { "type": "number", "minimum": 0 },
        "weight": { "type": "number", "minimum": 0 },
        "grade":  { "enum": ["A", "B", "C", "D", "F"] }
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "dimension", "severity", "title", "file", "fix", "source"],
      "properties": {
        "id":        { "type": "string", "pattern": "^C[0-9]{2,3}$" },
        "dimension": { "enum": ["discovery_metadata","scope_focus","conciseness","information_architecture","content_quality","tool_security","testing_examples","standards_compliance"] },
        "severity":  { "enum": ["fail", "warn", "info"] },
        "title":     { "type": "string" },
        "file":      { "type": "string" },
        "line":      { "type": ["integer", "null"], "minimum": 0 },
        "evidence":  { "type": "string" },
        "fix":       { "type": "string" },
        "source":    { "enum": ["structural", "heuristic", "qualitative"] }
      }
    }
  }
}
